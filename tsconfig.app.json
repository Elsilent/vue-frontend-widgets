{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["env.d.ts", "src/**/*", "src/**/*.vue"],
  "exclude": ["src/**/__tests__/*"],
  "compilerOptions": {
    "baseUrl": ".",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "noUnusedLocals" : false,
    "noUnusedParameters": false,
    "module": "ESNext",
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["vite/client"],
    "allowJs": true
  },
  "vueCompilerOptions": {
    "plugins": [
      "@vue/language-plugin-pug",
    ]
  }
}
